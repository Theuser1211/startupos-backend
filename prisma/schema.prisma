generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum JobType {
  BLUEPRINT_GENERATION
  WEBSITE_GENERATION
  DEPLOYMENT
}

enum DeploymentStatus {
  PENDING
  BUILDING
  DEPLOYING
  LIVE
  FAILED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  startups Startup[]
}

model Startup {
  id          String   @id @default(uuid())
  name        String
  description String?
  logo        String?
  industry    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  blueprint Blueprint?
  websites  Website[]
  jobs      Job[]
  events    StartupEvent[]
  healthSnapshots HealthScoreSnapshot[]
  actions   FounderAction[]
  competitors Competitor[]
  briefs      DailyBrief[]

  @@index([userId])
}

model Blueprint {
  id          String   @id @default(uuid())
  content     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  startupId String  @unique
  startup   Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)
}

model WebsiteSpec {
  id        String   @id @default(uuid())
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  websiteId String  @unique
  website   Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Website {
  id            String   @id @default(uuid())
  name          String
  content       Json
  status        String   @default("draft")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  startupId String
  startup   Startup    @relation(fields: [startupId], references: [id], onDelete: Cascade)

  spec  WebsiteSpec?
  deployment Deployment?
}

model Deployment {
  id        String           @id @default(uuid())
  status    DeploymentStatus @default(PENDING)
  url       String?
  provider  String?
  error     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  websiteId String  @unique
  website   Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Job {
  id        String    @id @default(uuid())
  type      JobType
  status    JobStatus @default(PENDING)
  payload   Json?
  result    Json?
  error     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  startupId String
  startup   Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@index([startupId])
  @@index([status])
}

enum EventType {
  STARTUP_CREATED
  BLUEPRINT_GENERATED
  BLUEPRINT_VIEWED
  WEBSITE_GENERATED
  WEBSITE_DEPLOYED
  DEPLOYMENT_FAILED
  DASHBOARD_VIEWED
}

model StartupEvent {
  id        String    @id @default(uuid())
  type      EventType
  metadata  Json?
  createdAt DateTime  @default(now())

  startupId String
  startup   Startup   @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@index([startupId])
  @@index([startupId, createdAt])
}

model HealthScoreSnapshot {
  id        String   @id @default(uuid())
  score     Int
  createdAt DateTime @default(now())

  startupId String
  startup   Startup  @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@index([startupId])
  @@index([startupId, createdAt])
}

model FounderAction {
  id          String   @id @default(uuid())
  action      String
  description String
  priority    String   @default("medium")
  link        String?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  startupId String
  startup   Startup  @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@index([startupId])
}

model Competitor {
  id          String   @id @default(uuid())
  name        String
  website     String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  startupId String
  startup   Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  snapshots CompetitorSnapshot[]
  changes   CompetitorChange[]

  @@index([startupId])
}

model CompetitorSnapshot {
  id          String   @id @default(uuid())
  title       String
  summary     String?
  pricing     String?
  features    Json?
  rawContent  String?
  capturedAt  DateTime @default(now())

  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([competitorId])
  @@index([competitorId, capturedAt])
}

model CompetitorChange {
  id          String   @id @default(uuid())
  type        String
  oldValue    String?
  newValue    String?
  detectedAt  DateTime @default(now())

  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([competitorId])
  @@index([competitorId, detectedAt])
}

model DailyBrief {
  id                String   @id @default(uuid())
  summary           String
  wins              Json
  priorities        Json
  competitorUpdates Json
  generatedAt       DateTime @default(now())

  startupId String
  startup   Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@index([startupId])
  @@index([startupId, generatedAt])
}

model ApiLog {
  id         String   @id @default(uuid())
  method     String
  path       String
  statusCode Int
  userId     String?
  ip         String?
  duration   Int
  createdAt  DateTime @default(now())
}